<UserControl x:Class="AINovel.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="系统配置" FontSize="24" FontWeight="Bold" Foreground="#1B95D9" Margin="0,0,0,20"/>

            <!-- GPT接口配置 -->
            <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="GPT接口配置" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>

                    <TextBlock Text="接口地址" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding GptApiUrl, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="https://api.openai.com/v1/chat/completions"/>

                    <TextBlock Text="API Key" Foreground="#666" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding GptApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="请输入API Key"/>

                    <TextBlock Text="模型" Foreground="#666" Margin="0,15,0,5"/>
                    <TextBox Text="{Binding GptModel, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxExtend}"
                             hc:InfoElement.Placeholder="如: gpt-3.5-turbo"/>

                    <TextBlock Text="Temperature" Foreground="#666" Margin="0,15,0,5"/>
                    <hc:NumericUpDown Value="{Binding GptTemperature}" Minimum="0" Maximum="2" Increment="0.1"
                                      Style="{StaticResource NumericUpDownExtend}"/>
                    <TextBlock Text="控制生成内容的随机性（0-2）" Foreground="#999" FontSize="12" Margin="0,5,0,0"/>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="测试连接" Command="{Binding TestConnectionCommand}"
                                Style="{StaticResource ButtonPrimary}"/>
                    </StackPanel>

                    <Border Padding="10" Margin="0,10,0,0"
                            CornerRadius="4" Visibility="{Binding ConnectionTestResult, Converter={StaticResource String2VisibilityConverter}}">
                        <TextBlock Text="{Binding ConnectionTestResult}" Foreground="#1976D9"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- 生成配置 -->
            <Border Background="White" CornerRadius="8" Padding="25" Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="生成配置" FontSize="18" FontWeight="Bold" Foreground="#333" Margin="0,0,0,20"/>

                    <hc:Row Margin="0,0,0,15">
                        <hc:Col Span="12">
                            <StackPanel>
                                <TextBlock Text="最大线程数" Foreground="#666" Margin="0,0,0,5"/>
                                <hc:NumericUpDown Value="{Binding MaxThreadCount}" Minimum="1" Maximum="10"
                                                  Style="{StaticResource NumericUpDownExtend}"/>
                                <TextBlock Text="控制并发生成任务数量" Foreground="#999" FontSize="12" Margin="0,5,0,0"/>
                            </StackPanel>
                        </hc:Col>
                        <hc:Col Span="12">
                            <StackPanel>
                                <TextBlock Text="自动生成阈值" Foreground="#666" Margin="0,0,0,5"/>
                                <hc:NumericUpDown Value="{Binding MinWaitGenerateCount}" Minimum="1" Maximum="100"
                                                  Style="{StaticResource NumericUpDownExtend}"/>
                                <TextBlock Text="待生成数量低于此值时自动触发" Foreground="#999" FontSize="12" Margin="0,5,0,0"/>
                            </StackPanel>
                        </hc:Col>
                    </hc:Row>
                </StackPanel>
            </Border>

            <!-- 保存按钮 -->
            <Button Content="保存配置" Command="{Binding SaveCommand}" Style="{StaticResource ButtonPrimary}"
                    HorizontalAlignment="Left" Margin="0,10,0,0" Width="120" Height="40"/>

            <TextBlock Text="{Binding StatusMessage}" Foreground="#1976D9" Margin="0,15,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
