<Window
    x:Class="AINovel.Views.CoreDetailWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="核心梗详情"
    Width="700"
    Height="550"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,20,8" />
        </Style>
        <Style x:Key="EditTextBox" TargetType="TextBox">
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="BorderBrush" Value="#D0D0D0" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  只读信息区  -->
        <Border Grid.Row="0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="序号:" />
                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValue}" FontWeight="Bold" Text="{Binding SerialNumber}" />

                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FieldLabel}" Text="状态:" />
                <TextBlock Grid.Row="0" Grid.Column="3" Style="{StaticResource FieldValue}" FontWeight="Bold" Foreground="#1B95D9" Text="{Binding StatusText}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" Style="{StaticResource FieldLabel}" Text="创建时间:" />
                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,0,20,0" Style="{StaticResource FieldValue}" Text="{Binding CreateTime}" />

                <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,0,8,0" Style="{StaticResource FieldLabel}" Text="生成时间:" />
                <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource FieldValue}" Text="{Binding GenerateTime}" />
            </Grid>
        </Border>

        <!--  可编辑内容区  -->
        <Border Grid.Row="1" Margin="0,15,0,0" Style="{StaticResource SectionBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="#1B95D9"
                    Text="核心梗内容" />

                <TextBox
                    Grid.Row="1"
                    Style="{StaticResource EditTextBox}"
                    Text="{Binding Content, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Border>

        <!--  按钮区  -->
        <StackPanel
            Grid.Row="2"
            Margin="0,15,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Margin="0,0,10,0"
                Padding="12,6"
                Click="OnSaveClick"
                Content="保存"
                FontWeight="Bold"
                Foreground="White"
                Background="#1B95D9"
                BorderThickness="0"
                Cursor="Hand" />
            <Button
                Padding="12,6"
                Click="OnCancelClick"
                Content="取消"
                Background="#F0F0F0"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                Cursor="Hand" />
        </StackPanel>
    </Grid>
</Window>
