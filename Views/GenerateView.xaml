<UserControl
    x:Class="AINovel.Views.GenerateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:conv="clr-namespace:AINovel.Converters"
    xmlns:helpers="clr-namespace:AINovel.Helpers">
    <UserControl.Resources>
        <conv:GenerateStatusConverter x:Key="GenerateStatusConverter"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,15"
            FontSize="24"
            FontWeight="Bold"
            Foreground="#1B95D9"
            Text="生成管理" />

        <!--  筛选工具栏  -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,15"
            Padding="15"
            Background="White"
            CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.1"
                    ShadowDepth="2" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#666"
                    Text="账号筛选:" />
                <ComboBox
                    Width="150"
                    DisplayMemberPath="AccountName"
                    ItemsSource="{Binding Accounts}"
                    SelectedItem="{Binding FilterAccount}"
                    Style="{StaticResource ComboBoxExtend}" />
                <TextBlock
                    Margin="10,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#666"
                    Text="CP筛选:" />
                <ComboBox
                    Width="150"
                    DisplayMemberPath="Name"
                    ItemsSource="{Binding Projects}"
                    SelectedItem="{Binding FilterCp}"
                    Style="{StaticResource ComboBoxExtend}" />
                <Button
                    Margin="10,0,20,0"
                    Command="{Binding RefreshCoresCommand}"
                    Content="刷新"
                    Style="{StaticResource ButtonDefault}" />

                <TextBlock
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"
                    Foreground="#666"
                    Text="状态筛选:" />
                <ComboBox
                    Width="120"
                    ItemsSource="{Binding StatusFilters}"
                    SelectedItem="{Binding FilterStatus}"
                    Style="{StaticResource ComboBoxExtend}" />
            </StackPanel>
        </Border>

        <!--  核心梗列表  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="0,0,15,0"
                Padding="15"
                Background="White"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2" />
                </Border.Effect>
                <DataGrid
                    AutoGenerateColumns="False"
                    BorderThickness="0"
                    CanUserAddRows="False"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    ItemsSource="{Binding Cores}"
                    SelectedItem="{Binding SelectedCore}"
                    SelectionMode="Extended"
                    SelectionUnit="FullRow"
                    helpers:DataGridBehavior.SelectedItems="{Binding SelectedCores, Mode=TwoWay}"
                    MouseDoubleClick="DataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="50"
                            Binding="{Binding Id}"
                            Header="ID"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding SerialNumber}"
                            Header="序号"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="150"
                            Binding="{Binding Content}"
                            Header="内容"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="80"
                            Binding="{Binding GenerateStatus, Converter={StaticResource GenerateStatusConverter}}"
                            Header="状态"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="120"
                            Binding="{Binding GenerateTime, StringFormat=yyyy-MM-dd HH:mm}"
                            Header="生成时间"
                            IsReadOnly="True" />
                        <DataGridTextColumn
                            Width="*"
                            Binding="{Binding FailReason}"
                            Header="失败原因"
                            IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!--  详情面板  -->
            <Border
                Grid.Column="1"
                Width="420"
                Padding="20"
                Background="White"
                CornerRadius="8"
                Visibility="{Binding HasSelectedContent, Converter={StaticResource Boolean2VisibilityConverter}}">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Opacity="0.1"
                        ShadowDepth="2" />
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#1B95D9"
                            Text="生成内容" />
                        <TextBlock
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Foreground="#999"
                            FontSize="13">
                            <Run Text="共 " />
                            <Run Text="{Binding ContentWordCount}" FontWeight="Bold" Foreground="#666" />
                            <Run Text=" 字" />
                        </TextBlock>
                    </Grid>
                    <Border
                        Height="400"
                        BorderBrush="#E0E0E0"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ScrollViewer
                            helpers:AutoScrollBehavior.AutoScroll="{Binding IsGenerating}">
                            <TextBox
                                Text="{Binding SelectedGenerateContent, Mode=OneWay}"
                                Padding="12"
                                FontSize="14"
                                FontFamily="Microsoft YaHei"
                                TextWrapping="Wrap"
                                VerticalAlignment="Stretch"
                                BorderThickness="0"
                                Background="Transparent" />
                        </ScrollViewer>
                    </Border>
                    <StackPanel
                        Margin="0,10,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding StopGenerationCommand}"
                            Content="终止生成"
                            Style="{StaticResource ButtonDanger}"
                            Visibility="{Binding IsGenerating, Converter={StaticResource Boolean2VisibilityConverter}}" />
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CopyTitleCommand}"
                            Content="复制标题"
                            Style="{StaticResource ButtonDefault}" />
                        <Button
                            Margin="0,0,8,0"
                            Command="{Binding CopyFreeContentCommand}"
                            Content="复制免费文"
                            Style="{StaticResource ButtonDefault}" />
                        <Button
                            Command="{Binding CopyPaidContentCommand}"
                            Content="复制付费文"
                            Style="{StaticResource ButtonDefault}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!--  操作按钮  -->
        <Border
            Grid.Row="3"
            Margin="0,15,0,0"
            Padding="15"
            Background="White"
            CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="10"
                    Opacity="0.1"
                    ShadowDepth="2" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Button
                    Margin="0,0,10,0"
                    Command="{Binding ViewContentCommand}"
                    Content="查看内容"
                    Style="{StaticResource ButtonDefault}" />
                <Button
                    Margin="0,0,10,0"
                    Command="{Binding GenerateCommand}"
                    Content="生成"
                    Style="{StaticResource ButtonPrimary}" />
                <Button
                    Margin="0,0,10,0"
                    Command="{Binding PublishCommand}"
                    Content="发布"
                    Style="{StaticResource ButtonSuccess}" />
                <Button
                    Command="{Binding DeleteCoreCommand}"
                    Content="删除"
                    Style="{StaticResource ButtonDanger}" />
                <TextBlock
                    Margin="20,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#1976D9"
                    Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>