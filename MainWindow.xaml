<Window x:Class="AINovel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:vm="clr-namespace:AINovel.ViewModels"
        xmlns:views="clr-namespace:AINovel.Views"
        mc:Ignorable="d"
        Title="AI在线小说生成程序" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边导航栏 - 蓝色主题 -->
        <Border Grid.Column="0" Background="#1B95D9">
            <DockPanel>
                <!-- Logo区域 -->
                <Border DockPanel.Dock="Top" Background="#1565A7" Padding="20,20,20,20">
                    <StackPanel>
                        <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="28" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="AI小说生成" FontSize="18" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 导航菜单 -->
                <ListBox x:Name="NavListBox"
                         DockPanel.Dock="Top"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding CurrentModule}"
                         SelectionChanged="NavListBox_SelectionChanged"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,10,0,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="25,14,25,14"/>
                            <Setter Property="Margin" Value="8,2,8,2"/>
                            <Setter Property="Foreground" Value="#BFFFFFFF"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                                Padding="{TemplateBinding Padding}" Margin="{TemplateBinding Margin}">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1565A7"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#1565A7"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding}" FontSize="14"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 底部版本信息 -->
                <Border DockPanel.Dock="Bottom" Padding="20,15" Background="#1565A7">
                    <TextBlock Text="v1.0.0" Foreground="#99FFFFFF" FontSize="12" HorizontalAlignment="Center"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- 主内容区 -->
        <Border Grid.Column="1" Background="#F0F4F8">
            <ContentControl Content="{Binding CurrentViewModel}">
                <ContentControl.Resources>
                    <DataTemplate DataType="{x:Type vm:HomeViewModel}">
                        <views:HomeView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:AccountViewModel}">
                        <views:AccountView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:PromptViewModel}">
                        <views:PromptView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:CpViewModel}">
                        <views:CpView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:FileUploadViewModel}">
                        <views:FileUploadView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:GenerateViewModel}">
                        <views:GenerateView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:ConfigViewModel}">
                        <views:ConfigView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type vm:BackupViewModel}">
                        <views:BackupView/>
                    </DataTemplate>
                </ContentControl.Resources>
            </ContentControl>
        </Border>
    </Grid>
</Window>